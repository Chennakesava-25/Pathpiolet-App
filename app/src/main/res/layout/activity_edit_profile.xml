<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/app_background"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48.dp"
            android:layout_height="48.dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:rotation="180"
            app:tint="#1A3B8B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Edit Profile"
            android:textColor="#1A3B8B"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSaveTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginEnd="16.dp"
            android:padding="8.dp"
            android:text="Save"
            android:textColor="#1A3B8B"
            android:textSize="18sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/app_divider"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20.dp"
            android:paddingTop="24.dp"
            android:paddingBottom="24.dp">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="100.dp"
                android:layout_height="100.dp"
                android:layout_gravity="center">
                <androidx.cardview.widget.CardView
                    android:layout_width="100.dp"
                    android:layout_height="100.dp"
                    app:cardCornerRadius="50.dp"
                    app:cardElevation="4.dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#8E99D6">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="V"
                            android:textColor="#FFFFFF"
                            android:textSize="40sp" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:layout_width="32.dp"
                    android:layout_height="32.dp"
                    android:layout_gravity="bottom|end"
                    app:cardBackgroundColor="#1A3B8B"
                    app:cardCornerRadius="16.dp">
                    <ImageView
                        android:layout_width="16.dp"
                        android:layout_height="16.dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="#FFFFFF" />
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12.dp"
                android:text="Tap to change profile picture"
                android:textColor="#7C86A2"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="24.dp" />

            <!-- Form Fields -->
            <include layout="@layout/item_edit_field" android:id="@+id/fieldFullName" />
            <include layout="@layout/item_edit_field" android:id="@+id/fieldPhone" />
            <include layout="@layout/item_edit_field" android:id="@+id/fieldAge" />
            <include layout="@layout/item_edit_field" android:id="@+id/fieldEmail" />
            <include layout="@layout/item_edit_field" android:id="@+id/fieldEducation" />
            <include layout="@layout/item_edit_field" android:id="@+id/fieldInterested" />

            <View
                android:layout_width="match_parent"
                android:layout_height="32.dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56.dp"
                android:backgroundTint="#1A3B8B"
                android:text="Save Changes"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="16.dp" />

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16.dp"
                android:padding="12.dp"
                android:text="Cancel"
                android:textColor="#7C86A2"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
