<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9FF"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/splash_primary">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="24dp">

                <!-- Header Background -->
                <View
                    android:id="@+id/headerBg"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@drawable/bg_header_blue"
                    app:layout_constraintTop_toTopOf="parent"/>

                <!-- Back Button -->
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/white"
                    android:layout_marginTop="32dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="College Details"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    app:layout_constraintTop_toTopOf="@id/btnBack"
                    app:layout_constraintBottom_toBottomOf="@id/btnBack"
                    android:layout_marginStart="8dp"/>

                <!-- College Info Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="100dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white"
                    app:layout_constraintTop_toTopOf="@id/headerBg">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvCollegeName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Indian Institute of Science"
                            android:textColor="#1A237E"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/btnSave"
                            app:layout_constraintTop_toTopOf="parent"/>

                         <ImageView
                            android:id="@+id/btnSave"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/star_big_off"
                            app:tint="#757575"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/tvCollegeName"/>

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bengaluru, Karnataka"
                            android:textColor="#757575"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            app:drawableStartCompat="@drawable/ic_location_on"
                            android:drawablePadding="4dp"
                            app:drawableTint="#757575"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvCollegeName"/>

                        <TextView
                            android:id="@+id/badgeRank"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#1 NIRF Ranking"
                            android:textSize="12sp"
                            android:textColor="#3D5AFE"
                            android:textStyle="bold"
                            android:background="@drawable/bg_rank_badge"
                            android:backgroundTint="#E3F2FD"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginTop="12dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvLocation"/>

                        <TextView
                            android:id="@+id/badgeScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Score: 85.05"
                            android:textSize="12sp"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:background="@drawable/bg_rank_badge"
                            android:backgroundTint="#E8F5E9"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginStart="8dp"
                            app:layout_constraintStart_toEndOf="@id/badgeRank"
                            app:layout_constraintTop_toTopOf="@id/badgeRank"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                android:visibility="gone"/>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Key Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <include layout="@layout/item_stat_card" 
                         android:id="@+id/statFees"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_weight="1"
                         android:layout_marginEnd="8dp"/>
                
                <include layout="@layout/item_stat_card"
                         android:id="@+id/statPackage"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_weight="1"
                         android:layout_marginStart="8dp"/>
            </LinearLayout>

             <!-- About Section -->
             <TextView
                android:text="About Institute"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

             <TextView
                android:id="@+id/tvAbout"
                android:text="The Indian Institute of Science (IISc) is a public, deemed, research university for higher education and research in science, engineering, design, and management. It is located in Bengaluru, in the Indian city of Karnataka."
                android:textSize="14sp"
                android:textColor="#616161"
                android:lineSpacingExtra="4dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

             <!-- Website Link -->
             <TextView
                 android:id="@+id/tvWebsite"
                 android:text="Visit Official Website ↗"
                 android:textColor="#3D5AFE"
                 android:textStyle="bold"
                 android:layout_marginTop="12dp"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
