<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F9FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Custom Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <include
                android:id="@+id/btnBack"
                layout="@layout/layout_back_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Software Developer"
                android:textColor="@color/roadmap_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 1. Overview -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Overview" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="Develops applications, websites, enterprise software systems." />
            </androidx.cardview.widget.CardView>

            <!-- 2. Technical Skills -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Technical Skills" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="• C / C++ / Java / Python\n• Data Structures &amp; Algorithms\n• OOPS\n• Git &amp; GitHub\n• SQL\n• REST APIs" />
            </androidx.cardview.widget.CardView>

            <!-- 3. Soft Skills -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Soft Skills" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="• Logical thinking\n• Team collaboration\n• Communication" />
            </androidx.cardview.widget.CardView>

            <!-- 4. Roadmap -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Roadmap" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="Year 1 → C/Python basics\nYear 2 → DSA + OOPS\nYear 3 → Web/App dev + Internships\nYear 4 → System Design + Placement Prep" />
            </androidx.cardview.widget.CardView>

            <!-- 5. Projects -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Projects" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="• CRUD Web App\n• REST API Project\n• Final Year Full-stack Project" />
            </androidx.cardview.widget.CardView>

            <!-- 6. Salary -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Salary" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="• Fresher → ₹3–6 LPA\n• Mid → ₹8–15 LPA\n• Senior → ₹20+ LPA" />
            </androidx.cardview.widget.CardView>

            <!-- 7. Growth -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Growth" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="Developer → Senior Dev → Tech Lead → Engineering Manager → CTO" />
            </androidx.cardview.widget.CardView>

            <!-- 8. Recruiters -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:text="Recruiters" />
            <androidx.cardview.widget.CardView
                style="@style/ContentCardStyle">
                <TextView
                    style="@style/ContentTextStyle"
                    android:text="TCS, Infosys, Wipro, Accenture, Google, Amazon" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
