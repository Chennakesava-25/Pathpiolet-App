<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8.dp">

    <!-- Icon Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/iconContainer"
        android:layout_width="64.dp"
        android:layout_height="64.dp"
        android:layout_marginStart="8.dp"
        app:cardCornerRadius="16.dp"
        app:cardElevation="4.dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/iconBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_timeline_icon_blue" />

        <ImageView
            android:id="@+id/ivStepIcon"
            android:layout_width="32.dp"
            android:layout_height="32.dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_school"
            app:tint="@color/white" />
    </androidx.cardview.widget.CardView>

    <!-- Card Content -->
    <androidx.cardview.widget.CardView
        android:id="@+id/stepCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16.dp"
        android:layout_marginEnd="16.dp"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="20.dp"
        app:cardElevation="2.dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iconContainer"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16.dp">

            <TextView
                android:id="@+id/tvStepTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="10th"
                android:textColor="@color/timeline_text_title"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/btnArrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvStepSubtitle1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Foundation"
                android:textColor="@color/timeline_text_subtitle"
                android:textSize="14sp"
                app:layout_constraintEnd_toStartOf="@id/btnArrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvStepTitle" />

            <TextView
                android:id="@+id/tvStepSubtitle2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Choose your path"
                android:textColor="@color/roadmap_text_light"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/btnArrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvStepSubtitle1" />

            <ImageButton
                android:id="@+id/btnArrow"
                android:layout_width="40.dp"
                android:layout_height="40.dp"
                android:background="@drawable/bg_timeline_arrow_btn"
                android:src="@drawable/ic_chevron_right"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/timeline_text_subtitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
