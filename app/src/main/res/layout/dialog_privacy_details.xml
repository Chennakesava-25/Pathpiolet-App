<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24.dp"
    app:cardElevation="8.dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24.dp"
        android:background="@color/app_background">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Privacy"
                android:textColor="@color/app_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/btnClose"
                android:layout_width="24.dp"
                android:layout_height="24.dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/app_text_primary"
                android:alpha="0.6" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.dp"
            android:maxHeight="400dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Protection"
                    android:textColor="@color/app_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4.dp"
                    android:text="Your personal data is encrypted and stored securely. We use industry-standard protocols to ensure your information remains private."
                    android:textColor="@color/app_text_primary"
                    android:alpha="0.7"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16.dp"
                    android:text="Account Visibility"
                    android:textColor="@color/app_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4.dp"
                    android:text="Your profile details like email and phone number are only visible to you. Other users cannot see your personal contact information."
                    android:textColor="@color/app_text_primary"
                    android:alpha="0.7"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16.dp"
                    android:text="Third-party Sharing"
                    android:textColor="@color/app_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4.dp"
                    android:text="We do not sell your data to third parties. We only share anonymized aggregate data to improve our college recommendation engine."
                    android:textColor="@color/app_text_primary"
                    android:alpha="0.7"
                    android:textSize="13sp" />

            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnOk"
            android:layout_width="match_parent"
            android:layout_height="52.dp"
            android:layout_marginTop="24.dp"
            android:text="I Understand"
            android:backgroundTint="#1A3B8B"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12.dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
