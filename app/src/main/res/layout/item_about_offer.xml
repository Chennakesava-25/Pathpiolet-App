<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="8.dp">

    <View
        android:id="@+id/dot"
        android:layout_width="6.dp"
        android:layout_height="6.dp"
        android:background="@android:color/holo_orange_dark" />

    <TextView
        android:id="@+id/tvOfferText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12.dp"
        android:text="Personalized Career Roadmaps"
        android:textColor="#1A3B8B"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
