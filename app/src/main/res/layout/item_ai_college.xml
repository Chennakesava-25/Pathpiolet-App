<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/iconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#F5F5F5"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search" 
                app:tint="#616161"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintEnd_toStartOf="@id/badgeMatch"
            app:layout_constraintTop_toTopOf="parent">
            
            <TextView
                android:id="@+id/tvCollegeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IIT Bangalore"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"/>
                
            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bangalore, Karnataka"
                android:textColor="#757575"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_location_on"
                android:drawablePadding="4dp"
                android:drawableTint="#757575"/>
        </LinearLayout>

        <TextView
            android:id="@+id/badgeMatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="95% Match"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="@drawable/bg_rank_badge"
            android:backgroundTint="#3D5AFE"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Stats Row -->
        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/iconContainer">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#F5F9FF"
                android:padding="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Annual Fees"
                    android:textSize="10sp"
                    android:textColor="#757575"/>
                <TextView
                    android:id="@+id/tvFees"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹200K"
                    android:textStyle="bold"
                    android:textColor="#3D5AFE"
                    android:textSize="14sp"/>
            </LinearLayout>

            <View android:layout_width="8dp" android:layout_height="1dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#F5F9FF"
                android:padding="8dp">
                 <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avg Package"
                    android:textSize="10sp"
                    android:textColor="#757575"/>
                <TextView
                    android:id="@+id/tvPackage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹18 LPA"
                    android:textStyle="bold"
                    android:textColor="#3D5AFE"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Chips -->
        <com.google.android.material.chip.ChipGroup
             android:id="@+id/chipGroupTags"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:layout_marginTop="12dp"
             app:layout_constraintTop_toBottomOf="@id/statsRow">
             <com.google.android.material.chip.Chip
                 android:text="Government"
                 style="@style/Widget.Material3.Chip.Suggestion"
                 android:layout_width="wrap_content"
                 android:layout_height="32dp"
                 android:textSize="11sp"/>
             <com.google.android.material.chip.Chip
                 android:text="Hostel"
                 style="@style/Widget.Material3.Chip.Suggestion"
                 android:layout_width="wrap_content"
                 android:layout_height="32dp"
                 android:textSize="11sp"/>
        </com.google.android.material.chip.ChipGroup>

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="View Details"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:cornerRadius="8dp"
            app:backgroundTint="#3D5AFE"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnSave"
            app:layout_constraintTop_toBottomOf="@id/chipGroupTags"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_search" 
            app:iconTint="#424242"
            app:iconGravity="textStart"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:strokeColor="#E0E0E0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnViewDetails"
            app:layout_constraintBottom_toBottomOf="@id/btnViewDetails"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
