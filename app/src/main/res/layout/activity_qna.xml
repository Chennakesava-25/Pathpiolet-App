<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/btnBack"
            layout="@layout/layout_back_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="My QnA"
            android:textColor="#1A3B8B"
            android:textSize="18sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- Search Bar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16.dp"
            app:cardBackgroundColor="#F1F3F9"
            app:cardCornerRadius="24.dp"
            app:cardElevation="0.dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48.dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16.dp">
                <ImageView
                    android:layout_width="20.dp"
                    android:layout_height="20.dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#7C86A2" />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Search questions..."
                    android:paddingStart="8.dp"
                    android:textColor="#000000"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tabs Mockup -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16.dp"
            android:paddingBottom="16.dp">
            
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#4D6FFF"
                app:cardCornerRadius="12.dp"
                app:cardElevation="0.dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16.dp"
                    android:paddingVertical="8.dp"
                    android:text="All (1)"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16.dp"
                android:paddingVertical="8.dp"
                android:text="Answered (1)"
                android:textColor="#7C86A2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16.dp"
                android:paddingVertical="8.dp"
                android:text="Unanswered (0)"
                android:textColor="#7C86A2" />
        </LinearLayout>

        <!-- RecyclerView for QnA Items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvQna"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:listitem="@layout/item_qna" />
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAsk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24.dp"
        android:backgroundTint="#4D6FFF"
        android:src="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>
