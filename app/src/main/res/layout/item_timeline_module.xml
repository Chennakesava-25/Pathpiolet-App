<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Vertical Line Guide -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineLine"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="24dp" />

    <!-- Vertical Line -->
    <View
        android:id="@+id/timelineLine"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#4A69FF"
        app:layout_constraintStart_toStartOf="@+id/guidelineLine"
        app:layout_constraintEnd_toEndOf="@+id/guidelineLine"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Content Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardModule"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintStart_toStartOf="@+id/guidelineLine"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="36dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tvModuleDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="10th"
                android:textColor="#1F2C5C"
                android:textStyle="bold"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvModuleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Foundation"
                android:textColor="#4A69FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvModuleDate" />

            <TextView
                android:id="@+id/tvModuleSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                tools:text="Start your Computer Science journey"
                android:textColor="#7D849A"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnArrowContainer"
                app:layout_constraintTop_toBottomOf="@id/tvModuleTitle" />

            <TextView
                android:id="@+id/tvModuleStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="0 of 4 modules completed"
                android:textColor="#F2994A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvModuleSubtitle" />

            <!-- Like Button -->
            <ImageView
                android:id="@+id/btnLike"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="12dp"
                android:padding="4dp"
                android:src="@android:drawable/btn_star_big_off"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnArrowContainer"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#757575" />

            <!-- Arrow Button -->
            <FrameLayout
                android:id="@+id/btnArrowContainer"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_timeline_arrow_btn"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#4A69FF"/>
            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- Icon Container (Overlapping) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/iconContainer"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintStart_toStartOf="@+id/guidelineLine"
        app:layout_constraintEnd_toEndOf="@+id/guidelineLine"
        app:layout_constraintTop_toTopOf="@+id/cardModule"
        app:layout_constraintBottom_toBottomOf="@+id/cardModule">

        <FrameLayout
            android:id="@+id/viewIconBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_step_icon_purple_gradient">
            <ImageView
                android:id="@+id/ivModuleIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_school"
                app:tint="@color/white" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
